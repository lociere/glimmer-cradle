{
  "name": "@glimmer-cradle/kernel",
  "version": "0.1.8",
  "private": true,
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "tsx src/index.ts",
    "start:built": "node dist/index.js",
    "pretypecheck": "pnpm --filter @glimmer-cradle/protocol run build",
    "prebuild": "pnpm --filter @glimmer-cradle/protocol run build",
    "pretest": "pnpm --filter @glimmer-cradle/protocol run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --threads false"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.13.3",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "node-gyp": "^9.0.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "dependencies": {
    "@glimmer-cradle/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "env-paths": "^2.2.0",
    "fflate": "^0.8.2",
    "fs-extra": "^11.1.1",
    "rxjs": "^7.8.2",
    "semver": "^7.7.4",
    "winston": "^3.13.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zeromq": "^6.0.0"
  }
