{
  "name": "@glimmer-cradle/personal-server",
  "version": "0.1.7",
  "private": true,
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "pnpm run build:web && tsx src/index.ts",
    "build:web": "vite build",
    "preview:web": "vite preview",
    "pretest": "pnpm --filter @glimmer-cradle/protocol run build",
    "test": "tsx --test src/**/*.test.ts",
    "pretest:ui": "pnpm build",
    "test:ui": "playwright test",
    "test:ui:update": "playwright test --update-snapshots",
    "test:ui:report": "playwright show-report ../../build/reports/playwright/personal-server/report",
    "test:ui:install": "playwright install chromium",
    "pretypecheck": "pnpm --filter @glimmer-cradle/protocol run build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.playwright.json --noEmit",
    "prebuild": "pnpm --filter @glimmer-cradle/protocol run build",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@glimmer-cradle/protocol": "workspace:*",
    "ws": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.13.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
