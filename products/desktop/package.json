{
  "name": "@glimmer-cradle/desktop",
  "version": "0.1.2",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "sync:assets": "node ../../scripts/sync-assets.mjs",
    "dev": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "pretypecheck": "pnpm --filter @glimmer-cradle/protocol run build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.playwright.json --noEmit",
    "prebuild": "pnpm run sync:assets && pnpm --filter @glimmer-cradle/protocol run build",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build",
    "build:preload": "tsc -p tsconfig.preload.json",
    "start": "electron .",
    "preview": "vite preview",
    "test:ui": "playwright test",
    "test:ui:update": "playwright test --update-snapshots",
    "test:ui:report": "playwright show-report ../../build/reports/playwright/report",
    "test:ui:install": "playwright install chromium"
  },
  "dependencies": {
    "@glimmer-cradle/protocol": "workspace:*",
    "better-sqlite3": "11.10.0",
    "lucide-react": "^0.468.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.13.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^43.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
