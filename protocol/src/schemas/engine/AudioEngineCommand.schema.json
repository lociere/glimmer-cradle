{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/engine/AudioEngineCommand.schema.json",
  "title": "AudioEngineCommand",
  "description": "Kernel 与 Audio Engine 之间的单请求命令帧。",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "command", "payload"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "command": {
      "type": "string",
      "enum": ["health", "host.shutdown", "asr.warmup", "tts.warmup", "asr.recognize", "tts.synthesize"]
    },
    "payload": { "type": "object", "additionalProperties": true }
  }
}
