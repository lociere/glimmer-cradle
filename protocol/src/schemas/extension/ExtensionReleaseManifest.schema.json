{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/extension/ExtensionReleaseManifest.schema.json",
  "title": "ExtensionReleaseManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "schema_version", "extension", "channel", "source", "artifacts"],
  "properties": {
    "schema": { "const": "glimmer-cradle.extension-release" },
    "schema_version": { "const": 1 },
    "extension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "publisher"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*(?:\\.[a-z0-9][a-z0-9-]*)+$" },
        "version": { "type": "string", "pattern": "^(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$" },
        "publisher": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
      }
    },
    "channel": { "enum": ["stable", "beta", "nightly"] },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "revision"],
      "properties": {
        "repository": { "type": "string", "format": "uri", "pattern": "^https://" },
        "revision": { "type": "string", "pattern": "^[a-fA-F0-9]{7,64}$" },
        "tag": { "type": "string", "minLength": 1 }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/ExtensionReleaseArtifact" }
    }
  },
  "definitions": {
    "ExtensionReleaseArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform", "file", "media_type", "size", "sha256"],
      "properties": {
        "platform": { "enum": ["any", "windows-x64", "windows-arm64", "linux-x64", "linux-arm64", "darwin-x64", "darwin-arm64"] },
        "file": { "type": "string", "minLength": 1 },
        "media_type": { "const": "application/vnd.glimmer-cradle.extension+zip" },
        "size": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "signature": { "type": "string", "minLength": 1 },
        "provenance": { "type": "string", "minLength": 1 }
      }
    }
  }
}
