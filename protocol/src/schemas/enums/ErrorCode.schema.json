{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/enums/ErrorCode.schema.json",
  "title": "ErrorCode",
  "description": "跨层错误码 —— 字符串枚举，值=名。跨层单一事实源，Kernel 内核与 Cognition 认知核共用，随 IPC 错误响应 error.code 跨进程传递。归并历史：CORE_ERROR/UNKNOWN_ERROR→UNKNOWN；BRIDGE_ERROR/ADAPTER_ERROR→IPC_ERROR。",
  "type": "string",
  "enum": [
    "UNKNOWN",
    "CONFIG_ERROR",
    "LIFECYCLE_ERROR",
    "IPC_ERROR",
    "IPC_TIMEOUT",
    "PERSISTENCE_ERROR",
    "INFERENCE_ERROR",
    "CANCELLED",
    "EXTENSION_ERROR",
    "EXTENSION_VALIDATION_FAILED",
    "EXTENSION_SANDBOX_ERROR",
    "EXTENSION_PERMISSION_DENIED",
    "EXTENSION_LIFECYCLE_ERROR",
    "DOMAIN_ERROR",
    "MEMORY_NOT_FOUND",
    "PERSONA_VIOLATION",
    "EMOTION_ERROR"
  ]
}
