{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/ExtensionCommandResult.schema.json",
  "title": "ExtensionCommandResult",
  "type": "object",
  "required": ["request_id", "command_id", "status"],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "command_id": { "type": "string", "minLength": 3 },
    "status": { "type": "string", "enum": ["success", "error"] },
    "result": {},
    "message": { "type": "string" }
  }
}
