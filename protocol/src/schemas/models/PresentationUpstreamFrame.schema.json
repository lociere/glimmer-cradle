{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/PresentationUpstreamFrame.schema.json",
  "title": "PresentationUpstreamFrame",
  "description": "Presentation Plane 上行帧契约(client → kernel)。Unity Avatar Host 通过 host_hello 宣告实现与能力；Desktop Surface 通过 chat_input、audio_input 和 Avatar 请求提交用户交互。",
  "type": "object",
  "required": ["kind", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "host_hello",
        "host_ready",
        "chat_input",
        "audio_input",
        "avatar_presentation",
        "avatar_intent",
        "avatar_action_state",
        "config_snapshot_request",
        "conversation_history_request",
        "skill_catalog_request",
        "config_update_request",
        "config_test_request",
        "extension_install_prepare",
        "extension_install_commit",
        "extension_install_cancel",
        "extension_uninstall_request",
        "extension_lifecycle_request",
        "extension_command_request",
        "extension_runtime_projection_request",
        "shutdown_request",
        "perception",
        "scene_loaded",
        "scene_unloaded",
        "heartbeat",
        "pong",
        "animation_complete",
        "error"
      ],
      "description": "上行帧类型(discriminator)。host_hello 握手 + 能力宣告;host_ready 表示完成初始化;chat_input 用户直接输入(对话);perception 场景内交互发送(8.7+);scene_loaded/unloaded 场景生命周期回执;heartbeat/pong 心跳;animation_complete 动画结束反馈;error 错误上报。"
    },
    "trace_id": {
      "type": "string",
      "description": "全链路追踪 ID。chat_input / perception 等用户触发帧应携带，基础设施帧可省略。"
    },
    "timestamp": {
      "type": "number",
      "description": "Unix 毫秒时间戳"
    },
    "host_hello": {
      "$ref": "#/definitions/AvatarHostHelloPayload",
      "description": "kind=host_hello 时存在"
    },
    "host_ready": {
      "$ref": "#/definitions/AvatarHostReadyPayload",
      "description": "kind=host_ready 时存在。Unity Avatar Host 只在 Avatar Package、Composition Surface、首帧和交互均就绪后上报。"
    },
    "chat_input": {
      "$ref": "#/definitions/ChatInputPayload",
      "description": "kind=chat_input 时存在"
    },
    "audio_input": {
      "$ref": "#/definitions/AudioInputPayload",
      "description": "kind=audio_input 时存在。桌面端录音输入，Kernel 负责落盘、ASR 与后续感知注入。"
    },
    "avatar_presentation": {
      "$ref": "#/definitions/AvatarPresentationRequest",
      "description": "kind=avatar_presentation 时存在。Control Center 请求 Kernel 更新正式 Avatar 的呈现状态。"
    },
    "avatar_intent": {
      "$ref": "#/definitions/AvatarIntentRequest",
      "description": "kind=avatar_intent 时存在。Control Center 提交模型清单已声明的稳定身体动作意图。"
    },
    "avatar_action_state": {
      "$ref": "#/definitions/AvatarActionStateReportPayload",
      "description": "kind=avatar_action_state 时存在。Avatar 回报动作调度器的权威状态快照。"
    },
    "config_snapshot_request": {
      "$ref": "src/schemas/models/ConfigurationSnapshotRequest.schema.json"
    },
    "conversation_history_request": {
      "$ref": "src/schemas/models/ConversationHistoryRequest.schema.json"
    },
    "skill_catalog_request": {
      "$ref": "src/schemas/models/SkillCatalogRequest.schema.json"
    },
    "config_update_request": {
      "$ref": "src/schemas/models/ConfigurationUpdateRequest.schema.json"
    },
    "config_test_request": {
      "$ref": "src/schemas/models/ConfigurationTestRequest.schema.json"
    },
    "extension_install_prepare": {
      "$ref": "src/schemas/models/ExtensionInstallPrepareRequest.schema.json"
    },
    "extension_install_commit": {
      "$ref": "src/schemas/models/ExtensionInstallCommitRequest.schema.json"
    },
    "extension_install_cancel": {
      "type": "object",
      "required": ["request_id", "transaction_id"],
      "additionalProperties": false,
      "properties": {
        "request_id": { "type": "string" },
        "transaction_id": { "type": "string" }
      }
    },
    "extension_uninstall_request": {
      "$ref": "src/schemas/models/ExtensionUninstallRequest.schema.json"
    },
    "extension_lifecycle_request": {
      "$ref": "src/schemas/models/ExtensionLifecycleRequest.schema.json"
    },
    "extension_command_request": {
      "$ref": "src/schemas/models/ExtensionCommandRequest.schema.json"
    },
    "extension_runtime_projection_request": {
      "$ref": "src/schemas/models/ExtensionRuntimeProjectionRequest.schema.json"
    },
    "shutdown_request": {
      "$ref": "#/definitions/ShutdownRequestPayload",
      "description": "kind=shutdown_request 时存在。受信任桌面壳请求 Kernel 有序停止整套 Glimmer Cradle 进程。"
    },
    "perception": {
      "$ref": "#/definitions/PerceptionInputPayload",
      "description": "kind=perception 时存在(场景内交互 / scene 对象触发等通用感知通道)"
    },
    "scene_loaded": {
      "$ref": "#/definitions/SceneLifecyclePayload",
      "description": "kind=scene_loaded 时存在"
    },
    "scene_unloaded": {
      "$ref": "#/definitions/SceneLifecyclePayload",
      "description": "kind=scene_unloaded 时存在"
    },
    "animation_complete": {
      "$ref": "#/definitions/AnimationCompletePayload",
      "description": "kind=animation_complete 时存在"
    },
    "error": {
      "$ref": "#/definitions/AvatarHostErrorPayload",
      "description": "kind=error 时存在"
    }
  },
  "definitions": {
    "AvatarHostHelloPayload": {
      "type": "object",
      "required": ["host_kind"],
      "additionalProperties": false,
      "properties": {
        "host_kind": {
          "type": "string",
          "enum": ["unity"],
          "description": "当前 Avatar Host 实现类型。"
        },
        "host_id": {
          "type": "string",
          "description": "Avatar Host 实例唯一 ID。"
        },
        "host_version": {
          "type": "string",
          "description": "Avatar Host 实现版本。"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "expression",
              "motion",
              "avatar_intent",
              "lip_sync",
              "parameter",
              "audio_play",
              "load_scene",
              "load_extension_avatar_model",
              "load_extension_motion",
              "load_extension_scene",
              "load_extension_soundscape"
            ]
          },
          "description": "Avatar Host 声明能消费的下行帧类型和可加载贡献；Kernel 不发送未声明能力。"
        },
        "model_id": {
          "type": "string",
          "description": "当前激活的 Avatar Model ID。"
        },
        "avatar_package_id": {
          "type": "string",
          "description": "当前激活的身体资产包 ID。用于区分角色身体包与底层模型 ID。"
        }
      }
    },
    "AvatarHostReadyPayload": {
      "type": "object",
      "required": ["worker_window_state", "composition_surface_state", "first_frame_presented", "interaction_ready"],
      "additionalProperties": false,
      "properties": {
        "host_id": {
          "type": "string"
        },
        "model_id": {
          "type": "string"
        },
        "avatar_package_id": {
          "type": "string"
        },
        "worker_window_state": {
          "type": "string",
          "enum": ["isolated", "visible", "unknown"],
          "description": "Unity worker window 是否已经退居后台工作容器，避免启动闪窗。"
        },
        "composition_surface_state": {
          "type": "string",
          "enum": ["attached", "failed", "unknown"],
          "description": "正式透明合成表面是否已经附着。"
        },
        "first_frame_presented": {
          "type": "boolean",
          "description": "正式身体的首帧是否已经实际呈现到桌面。"
        },
        "interaction_ready": {
          "type": "boolean",
          "description": "模型 driver、输入 hull 与交互控制是否已经可用。"
        },
        "summary": {
          "type": "string",
          "description": "面向运行时和调试面的简要状态总结。"
        }
      }
    },
    "ChatInputPayload": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string",
          "description": "用户键盘输入的文本"
        },
        "source_suffix": {
          "type": "string",
          "description": "可选子来源标记(避免来自不同 UI 路径混淆)"
        }
      }
    },
    "AudioInputPayload": {
      "type": "object",
      "required": ["audio_id", "audio_data", "mime_type"],
      "additionalProperties": false,
      "properties": {
        "audio_id": {
          "type": "string",
          "description": "本次录音的唯一 ID，供去重、日志和 transcript 对齐。"
        },
        "audio_data": {
          "type": "string",
          "description": "Base64 编码音频数据。Control Center 当前发送 WAV，避免 ASR 依赖浏览器私有编码。"
        },
        "mime_type": {
          "type": "string",
          "description": "音频 MIME 类型，默认 audio/wav。"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "录音时长，毫秒。"
        },
        "sample_rate": {
          "type": "integer",
          "minimum": 8000,
          "description": "采样率，供诊断和后续重采样策略使用。"
        }
      }
    },
    "AvatarPresentationRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "placement_id": {
          "type": "string",
          "description": "用户请求采用的桌面驻留预设 ID。预设只决定完整透明表面在工作区内的可见比例与停靠位置。"
        },
        "display_scale": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2.5,
          "description": "用户请求的绝对显示倍率。"
        },
        "reset_placement": {
          "type": "boolean",
          "description": "请求清除保存的窗口位置并回到预设停靠位置。"
        }
      }
    },
    "AvatarIntentRequest": {
      "type": "object",
      "required": ["action_id", "operation"],
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1,
          "description": "模型动作清单声明的稳定语义 ID，如 expression.shy 或 pose.hand-raised。"
        },
        "operation": {
          "type": "string",
          "enum": ["trigger", "activate", "deactivate"],
          "description": "动作目标操作。一次性动作使用 trigger；可保持动作必须明确 activate 或 deactivate。"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "description": "用户显式请求的优先级提示；Shell 的行为导演仍保留最终仲裁权。"
        }
      }
    },
    "AvatarActionStateReportPayload": {
      "type": "object",
      "required": ["active_action_ids"],
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "type": "string",
          "description": "引发本次变化的动作 ID；完整快照可省略。"
        },
        "state": {
          "type": "string",
          "enum": ["inactive", "active", "running", "completed", "rejected"],
          "description": "动作调度结果。"
        },
        "active_action_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "Shell 当前全部已激活保持动作的权威快照。"
        },
        "message": {
          "type": "string",
          "description": "拒绝原因或面向用户的补充说明。"
        }
      }
    },
    "ShutdownRequestPayload": {
      "type": "object",
      "required": ["requested_by"],
      "additionalProperties": false,
      "properties": {
        "requested_by": {
          "type": "string",
          "enum": ["control-surface"],
          "description": "停机请求来源。仅允许受管产品控制表面发起全局停机。"
        },
        "reason": {
          "type": "string",
          "description": "人类可读的停机原因，供生命周期日志记录。"
        }
      }
    },
    "PerceptionInputPayload": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string",
          "description": "感知描述文本(如 '用户翻开了桌上的书')"
        },
        "address_mode": {
          "type": "string",
          "enum": ["direct", "ambient"],
          "description": "默认 direct(场景内主动交互);ambient 留给被动环境感知"
        },
        "scene_id": {
          "type": "string",
          "description": "触发来源的场景 ID(8.7+ scene extension 用)"
        },
        "object_id": {
          "type": "string",
          "description": "场景内触发对象 ID(8.7+ scene interactions 用)"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "description": "可选辅助信息(对象坐标 / 持续时间 / 其他场景上下文)"
        }
      }
    },
    "SceneLifecyclePayload": {
      "type": "object",
      "required": ["scene_id"],
      "additionalProperties": false,
      "properties": {
        "scene_id": {
          "type": "string",
          "description": "场景 ID"
        },
        "narrative": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scene_summary": {
              "type": "string",
              "description": "场景的叙事摘要(注入 Deliberate prompt,当前角色知道自己在哪)"
            },
            "atmosphere": {
              "type": "string",
              "description": "氛围描述(calm / intimate / energetic / ...)"
            }
          },
          "description": "场景加载完成时,shell 向 kernel 上报场景的 narrative,kernel 更新 narrative context"
        }
      }
    },
    "AnimationCompletePayload": {
      "type": "object",
      "required": ["animation_id"],
      "additionalProperties": false,
      "properties": {
        "animation_id": {
          "type": "string",
          "description": "完成的动画 ID(对应 motion_id / expression_id)"
        }
      }
    },
    "AvatarHostErrorPayload": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "description": "错误码(shell 端定义,如 model_load_failed / scene_not_found)"
        },
        "message": {
          "type": "string",
          "description": "人类可读错误描述"
        },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "description": "可选附加详情"
        }
      }
    }
  }
}
