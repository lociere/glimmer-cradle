{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/models/CapabilityScope.schema.json",
  "title": "CapabilityScope",
  "description": "能力在全局、来源、场景或会话边界内的可见范围。",
  "oneOf": [
    {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "global" }
      }
    },
    {
      "type": "object",
      "required": ["kind", "ids"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["source_provider", "scene", "conversation"] },
        "ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  ]
}
