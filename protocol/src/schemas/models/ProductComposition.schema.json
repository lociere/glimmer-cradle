{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/models/ProductComposition.schema.json",
  "title": "ProductComposition",
  "description": "产品发行物包含的能力组合；启用状态与用户偏好不属于该契约。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "display_name", "features"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 1 },
    "id": { "enum": ["desktop", "personal-server"] },
    "display_name": { "type": "string", "minLength": 1 },
    "features": {
      "type": "object",
      "description": "Capabilities included in this product artifact. Enablement is owned by system configuration.",
      "additionalProperties": false,
      "required": ["control_surface_gateway", "local_device_actions", "avatar", "audio", "extensions"],
      "properties": {
        "control_surface_gateway": { "type": "boolean" },
        "local_device_actions": { "type": "boolean" },
        "avatar": { "type": "boolean" },
        "audio": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tts", "asr"],
          "properties": {
            "tts": { "type": "boolean" },
            "asr": { "type": "boolean" }
          }
        },
        "extensions": { "type": "boolean" }
      }
    }
  }
}
