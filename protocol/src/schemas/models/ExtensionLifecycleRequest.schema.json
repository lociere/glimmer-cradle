{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/ExtensionLifecycleRequest.schema.json",
  "title": "ExtensionLifecycleRequest",
  "type": "object",
  "required": ["request_id", "extension_id", "operation"],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "extension_id": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "minLength": 1 },
    "activation_profile": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*(?:[.-][a-z0-9_]+)*$"
    },
    "operation": { "type": "string", "enum": ["start", "stop"] }
  }
}
