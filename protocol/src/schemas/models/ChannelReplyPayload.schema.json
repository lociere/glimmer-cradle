{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/ChannelReplyPayload.schema.json",
  "title": "ChannelReplyPayload",
  "description": "通道回复事件载荷。Kernel 将 Cognition 的 ActionCommand 规范化为此事件，再分发给 Desktop Surfaces 或扩展适配器。属于 protocol 契约，不属于 extension-sdk 内部类型。",
  "type": "object",
  "required": ["trace_id", "text", "target_channel"],
  "additionalProperties": false,
  "properties": {
    "trace_id": {
      "type": "string",
      "description": "全链路追踪 ID，关联 perception → cognition → reply。"
    },
    "text": {
      "type": "string",
      "description": "本次认知回复的完整文本，用于记忆、日志和不支持多消息的通道兜底。"
    },
    "messages": {
      "type": "array",
      "items": { "$ref": "#/definitions/ChannelReplyMessage" },
      "description": "按投递顺序排列的自然消息段。支持同一次回复拆成多条消息。"
    },
    "emotion_state": {
      "$ref": "#/definitions/ChannelReplyEmotionSnapshot"
    },
    "target_channel": {
      "type": "string",
      "description": "目标通道。Desktop 为 desktop-ui:*；平台适配器使用 napcat:* 等命名空间。"
    }
  },
  "definitions": {
    "ChannelReplyMessage": {
      "type": "object",
      "required": ["sequence", "content_type", "text"],
      "additionalProperties": false,
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 0,
          "description": "同一次回复内的投递顺序，从 0 开始。"
        },
        "content_type": {
          "type": "string",
          "enum": ["text", "code"],
          "description": "消息内容类型。普通对话为 text；完整代码块可为 code。"
        },
        "text": {
          "type": "string",
          "description": "该条投递消息的正文。"
        },
        "language": {
          "type": ["string", "null"],
          "description": "content_type=code 时的语言标识。"
        }
      }
    },
    "ChannelReplyEmotionSnapshot": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "emotion_type": { "type": "string" },
        "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "trigger": { "type": ["string", "null"] }
      }
    }
  }
}
