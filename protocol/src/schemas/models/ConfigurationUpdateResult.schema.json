{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/models/ConfigurationUpdateResult.schema.json",
  "title": "ConfigurationUpdateResult",
  "type": "object",
  "required": ["request_id", "status", "apply_state", "change_summary"],
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["preview", "success", "conflict", "error"]
    },
    "apply_state": {
      "type": "string",
      "enum": ["unchanged", "restart_required", "restarting", "completed", "failed"]
    },
    "new_revision": {
      "type": "string"
    },
    "change_summary": {
      "type": "array",
      "items": { "type": "string" }
    },
    "snapshot": {
      "$ref": "ConfigurationSnapshot.schema.json"
    },
    "message": {
      "type": "string"
    }
  }
}
