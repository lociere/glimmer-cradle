{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/models/ConversationHistoryRequest.schema.json",
  "title": "ConversationHistoryRequest",
  "type": "object",
  "required": ["request_id"],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "conversation_id": { "type": "string" },
    "scene_id": { "type": "string" },
    "thread_id": { "type": "string" },
    "actor_id": { "type": "string" },
    "source_provider_id": { "type": "string" },
    "cursor": {
      "type": "string",
      "description": "不透明分页游标。缺省时返回最新一页。"
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200,
      "default": 50
    }
  }
}
