{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/models/ConfigurationUpdateRequest.schema.json",
  "title": "ConfigurationUpdateRequest",
  "type": "object",
  "required": ["request_id", "revision", "llm", "audio", "embedding", "memory", "skills"],
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string"
    },
    "revision": {
      "type": "string",
      "description": "客户端基于的快照修订号。"
    },
    "dry_run": {
      "type": "boolean",
      "description": "只生成预览，不提交。"
    },
    "llm": {
      "type": "object",
      "required": ["providers", "removed_provider_keys"],
      "additionalProperties": false,
      "properties": {
        "default_route_provider_key": {
          "type": "string"
        },
        "default_route_model_alias": {
          "type": "string"
        },
        "providers": {
          "type": "array",
          "items": { "$ref": "ConfigurationProviderDraft.schema.json" }
        },
        "removed_provider_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
          },
          "uniqueItems": true
        }
      }
    },
    "audio": {
      "$ref": "../config/AudioConfig.schema.json"
    },
    "embedding": {
      "$ref": "../config/EmbeddingConfig.schema.json"
    },
    "memory": {
      "$ref": "../config/MemoryConfig.schema.json"
    },
    "skills": {
      "$ref": "../config/SkillPlaneConfig.schema.json"
    }
  }
}
