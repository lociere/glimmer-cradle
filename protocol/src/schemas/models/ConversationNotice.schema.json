{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/models/ConversationNotice.schema.json",
  "title": "ConversationNotice",
  "type": "object",
  "required": ["code", "level", "title", "message"],
  "additionalProperties": false,
  "properties": {
    "code": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": ["info", "warning", "error"]
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "action_route": {
      "type": "string"
    },
    "action_label": {
      "type": "string"
    }
  }
}
