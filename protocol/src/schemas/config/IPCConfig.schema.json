{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/config/IPCConfig.schema.json",
  "title": "IPCConfig",
  "description": "IPC 通信层配置（TS ↔ Python）—— ZMQ 绑定 / 超时 / 重试 / 心跳。",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "bind_address": {
      "type": "string",
      "const": "tcp://127.0.0.1:*",
      "default": "tcp://127.0.0.1:*",
      "description": "ZMQ 回环绑定策略；实际端口由操作系统分配并由 EndpointRegistry 发布"
    },
    "request_timeout_ms": {
      "type": "integer",
      "minimum": 1000,
      "default": 30000,
      "description": "单次 IPC 请求超时（ms）"
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "default": 2,
      "description": "请求失败重试次数"
    },
    "retry_interval_ms": {
      "type": "integer",
      "minimum": 0,
      "default": 2000,
      "description": "重试间隔（ms）"
    },
    "heartbeat_interval_ms": {
      "type": "integer",
      "minimum": 1000,
      "default": 5000,
      "description": "Python 层心跳检测间隔（ms）"
    }
  }
}
