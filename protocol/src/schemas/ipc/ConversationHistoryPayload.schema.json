{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://glimmer-cradle.local/schemas/ipc/ConversationHistoryPayload.schema.json",
  "title": "ConversationHistoryPayload",
  "description": "Kernel 向 Cognition 请求 Conversation 投影历史页的 IPC 载荷。allowed_scopes 由 Kernel 依据当前产品上下文注入，浏览器不直接声明。",
  "type": "object",
  "required": ["request_id", "conversation_id", "scene_id", "thread_id", "source_provider_id", "allowed_scopes"],
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "conversation_id": { "type": "string", "minLength": 1 },
    "scene_id": { "type": "string", "minLength": 1 },
    "thread_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string" },
    "actor_name": { "type": "string" },
    "source_provider_id": { "type": "string", "minLength": 1 },
    "cursor": { "type": "string" },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200,
      "default": 50
    },
    "allowed_scopes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
