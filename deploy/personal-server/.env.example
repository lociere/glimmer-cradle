# 默认只绑定服务器回环地址，通过 SSH 隧道访问，不在公网传输明文 token。
GLIMMER_CRADLE_SITE_ADDRESS=:80
GLIMMER_CRADLE_HTTP_BIND=127.0.0.1
GLIMMER_CRADLE_HTTP_PORT=8080
GLIMMER_CRADLE_HTTPS_BIND=127.0.0.1
GLIMMER_CRADLE_HTTPS_PORT=8443

# 使用域名公开服务时，将上面五项改为：
# GLIMMER_CRADLE_SITE_ADDRESS=cradle.example.com
# GLIMMER_CRADLE_HTTP_BIND=0.0.0.0
# GLIMMER_CRADLE_HTTP_PORT=80
# GLIMMER_CRADLE_HTTPS_BIND=0.0.0.0
# GLIMMER_CRADLE_HTTPS_PORT=443

# 安装入口会在首次部署时生成随机值。不要提交真实 token。
GLIMMER_CRADLE_SERVER_TOKEN=GENERATE_ON_INSTALL
GLIMMER_CRADLE_OPERATIONS_BRIDGE_TOKEN=GENERATE_ON_INSTALL
GLIMMER_CRADLE_OPERATIONS_BRIDGE_SOCKET=/var/lib/glimmer-cradle/run/ops-bridge.sock

# deploy.sh 维护的当前不可变镜像。首次安装和每次成功更新后自动改写。
GLIMMER_CRADLE_IMAGE=glimmer-cradle/personal-server:0.1.8

# 默认由同一候选 OCI 镜像分别承载应用与 Caddy 入口进程，避免目标主机依赖第二个 registry 包。
GLIMMER_CRADLE_CADDY_IMAGE=glimmer-cradle/personal-server:0.1.8

# 源码仓库现场构建使用 source；正式发布包固定为 image 并直接拉取预构建 OCI 镜像。
GLIMMER_CRADLE_DEPLOYMENT_MODE=source
