# Glimmer Cradle repository boundary

# JavaScript / TypeScript dependencies and package-manager state
node_modules/
.pnpm-store/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Python environments, caches and packaging outputs
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.uv-cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Build, distribution, test and generated outputs
build/
dist/
output/
coverage/
playwright-report/
test-results/
/.playwright-cli/
scripts/output/
/products/desktop/src/renderer/public/assets/

# Local application data. Only the directory contract is versioned.
/data/*
!/data/README.md
/deploy/personal-server/state/

# Environment variables, credentials and private keys
.env
.env.*
!.env.example
!.env.*.example
*.key
*.pem
*.p12
*.pfx
*.keystore
secrets.yaml
secrets.json
secrets.toml
.npmrc
!.npmrc.example
/configs/secrets/*
!/configs/secrets/secrets.example.yaml
!/configs/secrets/*.example.json
!/configs/secrets/*.example.toml

# User-owned and third-party model or media assets
/assets/avatar/*
!/assets/avatar/README.md
!/assets/avatar/avatar-actions.schema.json
!/assets/avatar/avatar-behavior.schema.json
!/assets/avatar/avatar-packages.schema.json
!/assets/avatar/emotion-map.schema.json
/assets/models/
/assets/sounds/
*.gguf
*.safetensors
*.pt
*.pth
*.onnx
*.ckpt
*.bin
/engines/**/.cache/
/engines/**/models/
/engines/**/outputs/

# Native build outputs
/native/build/
/native/out/
*.dll
*.so
*.dylib
*.pyd
*.lib
*.exp
*.ilk
*.pdb

# Unity generated state, imported SDKs and private Avatar projections
/core/avatar/unity-host/Library/
/core/avatar/unity-host/Temp/
/core/avatar/unity-host/Obj/
/core/avatar/unity-host/Build/
/core/avatar/unity-host/Builds/
/core/avatar/unity-host/Logs/
/core/avatar/unity-host/UserSettings/
/core/avatar/unity-host/MemoryCaptures/
/core/avatar/unity-host/Assets/Live2D/
/core/avatar/unity-host/Assets/Live2D.meta
/core/avatar/unity-host/Assets/Plugins/AvatarPlugins/
/core/avatar/unity-host/Assets/Plugins/AvatarPlugins.meta
/core/avatar/unity-host/Assets/Plugins.meta
/core/avatar/unity-host/Assets/Resources/AvatarModels/
/core/avatar/unity-host/Assets/Resources/AvatarModels.meta
/core/avatar/unity-host/Assets/StreamingAssets/avatar/
/core/avatar/unity-host/Assets/StreamingAssets/avatar-registry.json
/core/avatar/unity-host/Assets/StreamingAssets/avatar-package-registry.json
