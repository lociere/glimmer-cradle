/core/avatar/unity-host/Assets/csc.rsp.meta
/core/avatar/unity-host/*.csproj
/core/avatar/unity-host/*.sln

# Process-local and legacy volatile directories
/temp/
/tmp/
/cache/
/logs/
/tts/
*.log

# IDE and operating-system state
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Tool-local state. Project instructions and canonical skills remain tracked.
/.claude/settings.local.json
/.claude/skills/
/.codex/config.toml
/.codex/settings.local.json
/.codex/sessions/
/.codex/logs/
/.codex/tmp/
/.agents/

# Local troubleshooting notes are not project facts.
/docs/troubleshooting/
